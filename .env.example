# ─────────────────────────────────────────────────────────────────────────────
# Stock Research with AI — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   cp .env.example .env
#   Fill in at minimum GROQ_API_KEY, then run:
#   docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Groq API key (primary LLM provider — models: mixtral-8x7b-32768, llama3, etc.)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# ── OPTIONAL — LLM Fallback ───────────────────────────────────────────────────

# Google Gemini API key (used as fallback if Groq is unavailable)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── OPTIONAL — Storage paths ──────────────────────────────────────────────────

# Directory where generated reports are saved (JSON, Markdown, PDF).
# Defaults to ./reports relative to the working directory.
# In Docker this is overridden to /home/app/project/reports (see docker-compose.yml).
# REPORTS_DIR=./reports

# ── OPTIONAL — Timeouts ───────────────────────────────────────────────────────

# Total time (seconds) allowed for a full research pipeline run
# RESEARCH_TIMEOUT_SECONDS=120

# TTL (seconds) for cached financial data
# CACHE_TTL_SECONDS=3600

# Timeout (seconds) for fetching data from Screener.in (Indian stocks)
# SCREENER_IN_TIMEOUT=30

# ── OPTIONAL — Feature Flags ──────────────────────────────────────────────────

# Set to "false" to disable Screener.in (useful when researching non-Indian stocks)
# ENABLE_SCREENER_IN=true

# Set to "false" to generate PDFs without embedded charts (faster, smaller files)
# PDF_INCLUDE_CHARTS=true

# ── OPTIONAL — UI ─────────────────────────────────────────────────────────────

# Maximum number of entries shown in the search history panel
# MAX_SEARCH_HISTORY=20

# ── OPTIONAL — Logging ────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
